<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🎂 Happy Birthday Sayangg💚💙</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:linear-gradient(135deg,#00c853,#2979ff);
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
overflow:hidden;
padding:20px;
}

.card{
background:#ffffff10;
backdrop-filter:blur(15px);
border-radius:25px;
padding:30px;
max-width:420px;
width:100%;
text-align:center;
box-shadow:0 10px 35px rgba(0,0,0,.3);
color:white;
}

h1{
font-size:32px;
margin-bottom:15px;
}

.photo{
width:230px;
height:230px;
margin:auto;
border-radius:50%;
overflow:hidden;
border:5px solid white;
box-shadow:0 0 25px rgba(255,255,255,.5);
}

.photo img{
width:100%;
height:100%;
object-fit:cover;
}

.music{
margin-top:20px;
font-size:18px;
}

.message{
margin-top:25px;
line-height:1.8;
font-size:17px;
}

footer{
margin-top:25px;
font-size:15px;
opacity:.9;
}

.heart{
position:fixed;
font-size:25px;
animation:naik 5s linear infinite;
opacity:0;
}

@keyframes naik{
0%{
transform:translateY(100vh);
opacity:0;
}
20%{
opacity:1;
}
100%{
transform:translateY(-120px);
opacity:0;
}
}
</style>
</head>

<body>

<div class="heart" style="left:10%;animation-delay:0s;">💚</div>
<div class="heart" style="left:30%;animation-delay:1s;">💙</div>
<div class="heart" style="left:50%;animation-delay:2s;">💚</div>
<div class="heart" style="left:70%;animation-delay:3s;">💙</div>
<div class="heart" style="left:90%;animation-delay:4s;">💚</div>

<div class="card">

<h1>🎂 Happy Birthday Radit 🎂</h1>

<div class="photo">
<img id="foto" src="foto1.jpeg">
</div>

<div class="music">
🎵 Now Playing<br>
<b>Our Song 💚💙</b>
</div>

<div class="message">
  
